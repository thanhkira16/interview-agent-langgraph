# Google Gemini API Key - Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=interview_agent

# Interview Configuration
NUM_QUESTIONS=5

# LangSmith Configuration - Get API key from: https://smith.langchain.com/settings
# Enable tracing and monitoring for LangGraph workflows
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=interview-agent

# HeyGen API Key (optional)
HEYGEN_API_KEY=your_heygen_api_key_here